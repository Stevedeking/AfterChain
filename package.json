{
    "name": "{{APP_ID}}",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:loader": "tsc --noEmit && vitest run --config vitest.config.ts",
        "preview": "npm run build && vite preview",
        "deploy": "wrangler deploy",
        "deploy:etherlink": "wrangler deploy --env etherlink",
        "cf-typegen": "wrangler types --include-runtime false"
    },
    "dependencies": {
        "hono": "4.11.5",
        "react": "19.2.3",
        "react-dom": "19.2.3",
        "react-router": "7.12.0",
        "viem": "latest"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "1.15.3",
        "@cloudflare/workers-types": "4.20260405.1",
        "@tailwindcss/vite": "4.1.18",
        "@types/node": "^25.5.2",
        "@types/react": "19.2.3",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "5.1.2",
        "hardhat": "^3.3.0",
        "tailwindcss": "4.1.18",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3",
        "vite": "7.3.0",
        "vitest": "2.1.2",
        "wrangler": "4.74.0"
    }
}
